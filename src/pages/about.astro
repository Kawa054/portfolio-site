---
import BaseLayout from '../layouts/BaseLayout.astro'
import {
  achievements,
  careerEntries,
  hobbies,
  papers,
  presentations,
  qualifications,
  skillRows
} from '../data/about'
import { ArrowUpRight, CodeXml, GraduationCap, Landmark, School } from '@lucide/astro'

const careerIcons = {
  school: School,
  university: Landmark,
  graduate: GraduationCap,
  work: CodeXml
}
---


<BaseLayout title="About" description="市川龍太郎の経歴、技術、趣味について。">
  <main
    id="content"
    class="tessellation-page relative min-h-screen scroll-mt-[13vh]"
    data-tab-root
  >
    <section class="page-surface min-h-screen px-5 py-14 md:px-8 md:pt-16">
      <div class="mx-auto flex w-full max-w-[1320px] flex-col justify-center gap-8 md:flex-row">
      <nav class="side-nav section-side-nav section-nav-panel shrink-0 rounded-[10px] md:min-h-[calc(100vh-5rem)] md:w-[230px]" aria-label="About page navigation">
        {['経歴', '技術', '資格・実績', '趣味'].map((item, index) => (
          <button
            type="button"
            class:list={[
              'side-nav-item group w-full text-left text-xl text-slate-700 transition md:text-2xl',
              index === 0 ? 'is-active' : ''
            ]}
            data-tab-button={index}
          >
            <span class="side-nav-index" data-tab-dot>{String(index + 1).padStart(2, '0')}</span>
            <span class="side-nav-label">{item}</span>
          </button>
        ))}
      </nav>

      <article class="content-panel min-h-[calc(100vh-5rem)] w-full max-w-[1040px] rounded-[10px] p-6 text-zinc-900 md:p-10">
        <section data-tab-panel="0" aria-labelledby="profile-title">
          <header class="content-heading mb-8 pb-5">
            <h1 id="profile-title" class="text-2xl font-bold tracking-normal md:text-4xl">市川 龍太郎 / Ryutaro Ichikawa</h1>
          </header>
          <ol>
            {careerEntries.map((item, index) => {
              const Icon = careerIcons[item.icon]

              return (
                <li class="grid grid-cols-[48px_minmax(0,1fr)] gap-x-4 md:grid-cols-[132px_56px_minmax(0,1fr)] md:gap-x-6">
                  <time class="col-start-2 row-start-1 mb-2 text-sm font-black tabular-nums text-zinc-600 md:col-start-1 md:mb-0 md:pt-4 md:text-base">
                    {item.period}
                  </time>

                  <div class="relative col-start-1 row-span-2 row-start-1 flex justify-center self-stretch md:col-start-2 md:row-span-1">
                    {index !== careerEntries.length - 1 && (
                      <span class="absolute bottom-[-24px] top-6 w-px bg-zinc-900/20 md:bottom-[-28px] md:top-7"></span>
                    )}
                    <span class:list={[
                      'relative z-[1] grid h-12 w-12 place-items-center rounded-[8px] shadow-[0_10px_24px_rgb(24_24_27/0.14)] md:h-14 md:w-14',
                      item.iconClass
                    ]}>
                      <Icon aria-hidden="true" size={26} stroke-width={1.8} />
                    </span>
                  </div>

                  <div class:list={[
                    'col-start-2 row-start-2 min-w-0 md:col-start-3 md:row-start-1',
                    index !== careerEntries.length - 1 ? 'pb-8' : ''
                  ]}>
                    <div class="min-w-0">
                      <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                        <h2 class="text-xl font-bold leading-tight text-zinc-950 md:text-2xl">{item.organization}</h2>
                        {item.duration && (
                          <span class="text-base font-black text-zinc-900/20 md:text-lg">{item.duration}</span>
                        )}
                        {item.achievement && (
                          <span class="text-sm font-bold text-zinc-900/20 md:text-base">{item.achievement}</span>
                        )}
                      </div>
                      <p class="mt-2 text-base font-semibold text-zinc-600 md:text-lg">
                        {item.detail}
                        {item.note && <span class="ml-2 text-sm font-medium text-zinc-500">({item.note})</span>}
                      </p>
                    </div>

                    {item.works.length > 0 && (
                      <div class="mt-5">
                        <ul class="grid gap-3 xl:grid-cols-2">
                          {item.works.map((work) => (
                            <li>
                              <a
                                href={work.href}
                                class="group flex min-h-[82px] overflow-hidden rounded-[6px] border border-zinc-900/10 bg-white/65 shadow-[0_8px_20px_rgb(24_24_27/0.045)] transition hover:-translate-y-0.5 hover:border-zinc-900/25 hover:bg-white hover:shadow-[0_12px_26px_rgb(24_24_27/0.08)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#0369a1]"
                              >
                                <span class="block h-20 w-24 shrink-0 overflow-hidden border-r border-zinc-900/10 bg-zinc-50 p-2 md:h-24 md:w-32">
                                  <img src={work.image} alt="" class="h-full w-full object-contain transition duration-200 group-hover:scale-[1.03]">
                                </span>
                                <span class="flex min-w-0 flex-1 items-center gap-3 px-3 py-3 md:px-4">
                                  <span class="min-w-0 flex-1 text-sm font-bold leading-5 text-zinc-800 md:text-base">{work.title}</span>
                                  <ArrowUpRight aria-hidden="true" size={18} stroke-width={2} class="shrink-0 text-zinc-400 transition group-hover:-translate-y-0.5 group-hover:translate-x-0.5 group-hover:text-zinc-800" />
                                </span>
                              </a>
                            </li>
                          ))}
                        </ul>
                      </div>
                    )}
                  </div>
                </li>
              )
            })}
          </ol>
        </section>

        <section class="hidden" data-tab-panel="1" aria-labelledby="skills-title">
          <header class="content-heading mb-6 pb-5">
            <h1 id="skills-title" class="text-3xl font-bold">技術</h1>
          </header>
          <div class="space-y-3 md:pl-5">
            {skillRows.map((row) => (
              <section class="flex min-w-0 items-start gap-4 md:gap-6">
                <button
                  type="button"
                  class="group grid h-[70px] w-[70px] shrink-0 place-items-center rounded transition hover:scale-110 hover:bg-white/55 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#ee7800] md:h-[86px] md:w-[86px]"
                  aria-label={`技術レベル${row.level}`}
                  title={`技術レベル${row.level}`}
                  data-info-card
                  data-info-title={`技術レベル${row.level}`}
                  data-info-description={row.description}
                  data-info-image={row.star}
                >
                  <img src={row.star} alt="" class="h-[62px] w-[62px] object-contain md:h-[78px] md:w-[78px]">
                </button>
                <div class="min-w-0 flex-1 border-l-[3px] border-[#1e4f012f] pl-4 md:min-h-[104px] md:pl-6">
                  <ul
                    class="mr-auto flex w-full flex-nowrap justify-start gap-3 overflow-x-auto pb-2 md:grid md:gap-2 md:overflow-visible md:pb-0"
                    style={`grid-template-columns: repeat(${row.skills.length}, minmax(0, 1fr)); max-width: ${row.skills.length * 94 - 8}px;`}
                  >
                    {row.skills.map((skill) => (
                      <li class="shrink-0 md:min-w-0">
                        <button
                          type="button"
                          class="group grid h-[64px] w-[64px] place-items-center rounded p-1 transition hover:scale-105 hover:bg-white/65 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#ee7800] md:aspect-square md:h-auto md:w-full md:max-w-[86px]"
                          aria-label={skill.name}
                          title={skill.name}
                          data-info-card
                          data-info-title={skill.name}
                          data-info-description={skill.description}
                          data-info-image={skill.icon}
                        >
                          <img src={skill.icon} alt="" class="h-[84%] w-[84%] object-contain">
                        </button>
                      </li>
                    ))}
                  </ul>
                </div>
              </section>
            ))}
          </div>
        </section>

        <section class="hidden" data-tab-panel="2" aria-labelledby="credentials-title">
          <header class="content-heading mb-8 pb-5">
            <h1 id="credentials-title" class="text-3xl font-bold">資格・実績</h1>
          </header>

          <div class="space-y-3">
              <section class="feature-card rounded-md p-4">
                <div class="mb-3">
                  <h2 class="text-xl font-bold">資格</h2>
                </div>
                <ul class="flex flex-wrap gap-2">
                  {qualifications.map((item) => (
                    <li class="rounded bg-zinc-900 px-3 py-2 text-sm font-bold text-white shadow-[0_8px_18px_rgb(24_24_27/0.08)]">
                      {item}
                    </li>
                  ))}
                </ul>
              </section>

              <section class="feature-card rounded-md p-4">
                <div class="mb-3">
                  <h2 class="text-xl font-bold">実績・受賞</h2>
                </div>
                <ul class="space-y-3">
                  {achievements.map((item) => (
                    <li class="rounded bg-white/70 px-4 py-3 text-base font-semibold leading-7 shadow-[0_6px_14px_rgb(24_24_27/0.035)]">
                      {item}
                    </li>
                  ))}
                </ul>
              </section>

              <section class="feature-card rounded-md p-4">
                <div class="mb-3">
                  <h2 class="text-xl font-bold">論文</h2>
                </div>
                <ul class="space-y-3">
                  {papers.map((paper) => (
                    <li class="rounded bg-white/70 p-4 shadow-[0_6px_14px_rgb(24_24_27/0.035)] transition hover:-translate-y-0.5 hover:bg-white">
                      <div class="mb-3 flex flex-wrap items-center gap-2">
                        <time class="rounded bg-zinc-900 px-3 py-1 text-xs font-bold text-white">{paper.date}</time>
                        <span class="text-xs font-bold text-zinc-500">{paper.venue}</span>
                      </div>
                      <a class="text-base font-bold leading-7 text-zinc-950 underline decoration-zinc-400 underline-offset-4 transition hover:text-[#ee7800]" href={paper.url} target="_blank" rel="noreferrer">
                        {paper.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </section>

            <section class="feature-card rounded-md p-4">
              <div class="mb-4">
                <h2 class="text-xl font-bold">学会発表</h2>
              </div>
              <ol class="space-y-3">
                {presentations.map((presentation) => (
                  <li class="group grid gap-4 rounded-md bg-white/72 p-4 shadow-[0_8px_20px_rgb(24_24_27/0.045)] transition hover:-translate-y-0.5 hover:bg-white md:grid-cols-[120px_1fr]">
                    <time class:list={[
                      'flex h-full min-h-20 items-center justify-center rounded px-3 py-4 text-center text-sm font-bold text-white',
                      presentation.planned ? 'bg-[#ee7800]' : 'bg-zinc-900'
                    ]}>
                      {presentation.date}
                    </time>
                    <div>
                      <div class="flex flex-wrap items-center gap-2">
                        <p class="text-sm font-semibold uppercase tracking-normal text-zinc-500">{presentation.event}</p>
                        {presentation.planned && (
                          <span class="rounded bg-[#ee7800]/12 px-2 py-1 text-xs font-bold text-[#a64f00]">予定</span>
                        )}
                      </div>
                      <h3 class="mt-2 text-lg font-bold leading-7 text-zinc-950">{presentation.title}</h3>
                    </div>
                  </li>
                ))}
              </ol>
            </section>
          </div>
        </section>

        <section class="hidden" data-tab-panel="3" aria-labelledby="hobbies-title">
          <h1 id="hobbies-title" class="content-heading mb-8 pb-5 text-3xl font-bold">趣味</h1>
          <div class="grid gap-5 lg:grid-cols-3">
            {hobbies.map((hobby) => (
              <section class="feature-card rounded-md p-5">
                <h2 class="mb-4 text-center text-xl font-bold">{hobby.title}</h2>
                <p class="text-base leading-8">{hobby.text}</p>
              </section>
            ))}
          </div>
        </section>
      </article>
      </div>
    </section>
  </main>
</BaseLayout>
