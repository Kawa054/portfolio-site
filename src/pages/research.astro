---
import BaseLayout from '../layouts/BaseLayout.astro'
import ContentParagraph from '../components/content/ContentParagraph.astro'
import StandardMapExperiment from '../components/research/StandardMapExperiment.astro'
import { researchTopics } from '../data/research'
---

<BaseLayout title="Research" description="折り紙と力学系、KAM定理に関する研究内容。">
  <main
    id="content"
    class="tessellation-page relative min-h-screen scroll-mt-[13vh]"
    data-tab-root
    data-tab-param="topic"
  >
    <section class="page-surface min-h-screen px-5 py-14 md:px-8 md:pt-16">
      <div class="mx-auto flex w-full max-w-[1500px] flex-col justify-center gap-6 md:flex-row">
      <nav class="side-nav section-side-nav section-nav-panel shrink-0 rounded-[10px] md:min-h-[calc(100vh-5rem)] md:w-[250px]" aria-label="Research page navigation">
        {researchTopics.map((topic, index) => (
          <button
            type="button"
            class:list={[
              'side-nav-item group w-full text-left text-lg text-slate-700 transition md:text-xl',
              index === 0 ? 'is-active' : ''
            ]}
            data-tab-button={index}
          >
            <span class="side-nav-index" data-tab-dot>{String(index + 1).padStart(2, '0')}</span>
            <span class="side-nav-label">{topic.title}</span>
          </button>
        ))}
      </nav>

      <article class="content-panel min-h-[calc(100vh-5rem)] w-full max-w-[1220px] rounded-[10px] p-5 text-zinc-900 md:p-7">
        {researchTopics.map((topic, index) => (
          <section class:list={[index !== 0 ? 'hidden' : '', '']} data-tab-panel={index} aria-labelledby={`research-${index}`}>
            <header class="content-heading mb-6 pb-5">
              <h1 id={`research-${index}`} class="text-3xl font-bold md:text-4xl">{topic.heading}</h1>
            </header>
            {topic.image && (
              <div class="feature-card mb-8 rounded-md p-3">
                <img src={topic.image} alt={topic.heading} data-lightbox-image class="max-h-[340px] w-full cursor-zoom-in rounded-md object-contain bg-white">
              </div>
            )}
            <div class="space-y-8">
              {topic.sections.map((section) => (
                <section class="feature-card rounded-md p-4 md:p-5">
                  {section.title && <h2 class="mb-5 text-2xl font-bold">{section.title}</h2>}
                  {section.blocks && (
                    <div class="space-y-6">
                      {section.blocks.map((block) => (
                        block.type === 'paragraphs'
                          ? (
                              <div class="space-y-5 text-base leading-8 md:text-lg">
                                {block.paragraphs.map((paragraph) => <ContentParagraph paragraph={paragraph} />)}
                              </div>
                            )
                          : (
                              <div class="space-y-5">
                                {block.figures.map((figure) => (
                                  <figure>
                                    <img
                                      src={figure.src}
                                      alt={figure.alt}
                                      data-lightbox-image
                                      class="w-full cursor-zoom-in rounded-md bg-white object-contain shadow-[0_6px_18px_rgb(24_24_27/0.08)] transition hover:brightness-95"
                                    >
                                    {figure.caption && (
                                      <figcaption class="mt-3 text-center text-sm text-zinc-500">
                                        {figure.caption}
                                      </figcaption>
                                    )}
                                  </figure>
                                ))}
                              </div>
                            )
                      ))}
                    </div>
                  )}
                  {section.paragraphs && (
                    <div class="space-y-5 text-base leading-8 md:text-lg">
                      {section.paragraphs.map((paragraph) => <ContentParagraph paragraph={paragraph} />)}
                    </div>
                  )}
                  {section.links && (
                    <ul class="mt-5 space-y-2">
                      {section.links.map((link) => (
                        <li>
                          <a
                            class="text-base font-medium text-[#007f8f] underline decoration-[#007f8f]/40 underline-offset-4 transition hover:text-[#d95f02] hover:decoration-[#d95f02] md:text-lg"
                            href={link.url}
                            target="_blank"
                            rel="noreferrer"
                          >
                            {link.label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  )}
                  {section.figures && (
                    <div class:list={['space-y-5', section.paragraphs ? 'mt-6' : '']}>
                      {section.figures.map((figure) => (
                        <figure>
                          <img
                            src={figure.src}
                            alt={figure.alt}
                            data-lightbox-image
                            class="w-full cursor-zoom-in rounded-md bg-white object-contain shadow-[0_6px_18px_rgb(24_24_27/0.08)] transition hover:brightness-95"
                          >
                          {figure.caption && (
                            <figcaption class="mt-3 text-center text-sm text-zinc-500">
                              {figure.caption}
                            </figcaption>
                          )}
                        </figure>
                      ))}
                    </div>
                  )}
                  {section.paragraphsAfterFigures && (
                    <div class="mt-6 space-y-5 text-base leading-8 md:text-lg">
                      {section.paragraphsAfterFigures.map((paragraph) => <ContentParagraph paragraph={paragraph} />)}
                    </div>
                  )}
                  {section.images && (
                    <div class:list={[
                      'mt-6 grid gap-2 sm:grid-cols-2',
                      section.galleryColumns === 2 ? 'lg:grid-cols-2' : 'lg:grid-cols-3'
                    ]}>
                      {section.images.map((image) => (
                        <img
                          src={image}
                          alt=""
                          data-lightbox-image
                          class:list={[
                            'w-full cursor-zoom-in rounded-md bg-white object-contain shadow-[0_6px_18px_rgb(24_24_27/0.05)] transition hover:brightness-95',
                            section.galleryColumns === 3 ? 'aspect-square' : 'h-full max-h-[340px] p-1'
                          ]}
                        >
                      ))}
                    </div>
                  )}
                  {section.widget === 'standard-map-experiment' && <StandardMapExperiment />}
                  {section.videos && (
                    <div class="mt-6 grid gap-4 lg:grid-cols-2">
                      {section.videos.map((videoId) => (
                        <iframe
                          class="aspect-video w-full rounded-md bg-black"
                          src={`https://www.youtube-nocookie.com/embed/${videoId}`}
                          title="YouTube video player"
                          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                          allowfullscreen
                        />
                      ))}
                    </div>
                  )}
                </section>
              ))}
            </div>
          </section>
        ))}
      </article>
      </div>
    </section>
  </main>
</BaseLayout>
