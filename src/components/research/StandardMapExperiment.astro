<section class="mt-5 border-t border-zinc-200 pt-5" data-standard-map-experiment>
  <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
    <h2 class="text-xl font-bold md:text-2xl">標準写像の数値実験</h2>
    <output
      class="min-w-24 font-mono text-lg font-bold text-[#007f8f]"
      data-epsilon-output
      aria-live="polite"
    >ε = 0.50</output>
  </div>

  <div class="mb-4 grid gap-3 md:grid-cols-[minmax(0,1fr)_auto] md:items-end">
    <label class="grid gap-2 text-sm font-semibold text-zinc-700">
      <span>摂動パラメータ ε</span>
      <input
        class="h-8 w-full cursor-pointer accent-[#007f8f]"
        type="range"
        min="0"
        max="3"
        step="0.01"
        value="0.5"
        data-epsilon-input
      >
    </label>

    <div
      class="grid grid-cols-5 overflow-hidden rounded-md border border-zinc-300 bg-white"
      role="group"
      aria-label="摂動パラメータの代表値"
    >
      {[0, 0.5, 1, 2, 3].map((value) => (
        <button
          type="button"
          class="min-h-9 min-w-12 border-l border-zinc-200 px-2 text-sm font-semibold text-zinc-600 transition first:border-l-0 hover:bg-zinc-100"
          data-epsilon-preset={value}
          aria-pressed={value === 0.5 ? 'true' : 'false'}
        >
          {value}
        </button>
      ))}
    </div>
  </div>

  <div
    class="mx-auto aspect-square w-full max-w-[680px] overflow-hidden rounded-md border border-zinc-300 bg-white"
    data-standard-map-stage
  >
    <img
      src="/dyn/standard-map/epsilon-0-5.png"
      alt="標準写像の相図。横軸はtheta、縦軸はI、摂動パラメータepsilonは0.5。"
      class="block h-full w-full object-contain"
      data-standard-map-output
    >
    <canvas
      hidden
      data-standard-map-canvas
      aria-hidden="true"
    ></canvas>
  </div>
</section>

<script>
  import { bindStandardMapExperiments } from '../../scripts/standard-map-experiment'

  bindStandardMapExperiments()
</script>
