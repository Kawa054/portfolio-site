---
import HeroCanvas from '../HeroCanvas.astro'
---

<section class="relative min-h-[58vh] overflow-hidden bg-black md:min-h-[87vh]" aria-label="Portfolio first view">
  <div class="pointer-events-none absolute left-0 top-[10vh] z-10 w-full text-center md:left-[-25%] md:top-[20vh]">
    <p class="font-script m-0 text-[clamp(8.8rem,9vw,10rem)] font-medium leading-none text-black [-webkit-text-stroke:1px_#fff]">
      Portfolio
    </p>
    <p class="font-script -mt-[2.5vh] text-[clamp(5.1rem,3.7vw,4.3rem)] font-medium text-white md:-mt-[-1.6vh]">
      Ryutaro Ichikawa
    </p>
  </div>
  <HeroCanvas />
</section>

